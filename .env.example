# Server
PORT=1911

# Content directory (default: ./content)
CONTENT_DIR=

# GitHub webhook (optional — for auto-deploy)
GITHUB_WEBHOOK_SECRET=

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Site metadata (used in RSS feed, sitemap, OpenGraph tags)
SITE_URL=
SITE_TITLE=The Chair
SITE_DESCRIPTION=A lightweight blog powered by agents

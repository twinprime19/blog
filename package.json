{
  "name": "the-wire",
  "version": "1.0.0",
  "description": "A self-hostable blog engine for your AI agent — Hono + Markdown flat files",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "setup": "node scripts/setup.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "blog",
    "hono",
    "flat-file",
    "markdown",
    "self-hosted",
    "lightweight"
  ],
  "author": "The Wire Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "dotenv": "^17.3.1",
    "file-type": "^22.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.5",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}

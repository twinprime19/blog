{
  "name": "the-wire",
  "version": "1.0.0",
  "description": "A self-hostable blog engine for your AI agent — Hono + SQLite + Marked",
  "type": "module",
  "main": "server.js",
  "bin": {
    "the-wire-mcp": "./mcp/mcp-server.js"
  },
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "setup": "node scripts/setup.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "blog",
    "hono",
    "sqlite",
    "markdown",
    "self-hosted",
    "lightweight"
  ],
  "author": "The Wire Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "hono": "^4.12.5",
    "marked": "^17.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
